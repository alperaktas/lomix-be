                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Kullanıcı odadan atıldı"
          },
          "403": {
            "description": "Yetkisiz"
          },
          "404": {
            "description": "Oda bulunamadı"
          }
        }
      }
    },
    "/api/mobile/room/leave": {
      "post": {
        "summary": "Odadan Ayrıl",
