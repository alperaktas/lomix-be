          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "roomId"
                ],
                "properties": {
                  "roomId": {
                    "type": "string"
                  }
                }
