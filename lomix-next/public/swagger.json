      "get": {
        "summary": "Mail kuyruk durumunu getir",
        "tags": [
          "Mobile System"
        ],
        "responses": {
          "200": {
            "description": "Kuyruk istatistikleri",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "waiting": {
                      "type": "integer"
                    },
                    "active": {
                      "type": "integer"
                    },
                    "completed": {
                      "type": "integer"
                    },
                    "failed": {
                      "type": "integer"
                    },
                    "delayed": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
