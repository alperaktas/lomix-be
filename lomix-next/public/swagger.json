              }
            }
          }
        }
      },
      "get": {
        "summary": "Oda mesaj geçmişini getir",
        "tags": [
          "Mobile Rooms"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "roomId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ]
      }
    },
    "/api/mobile/room/mic/leave": {
